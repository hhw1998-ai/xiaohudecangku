{
  "name": "Consulting Radar Source Registry",
  "version": "0.1.0",
  "updated_at": "2026-06-13",
  "principles": [
    "优先接入公开权威网页、公告页和公开报告页",
    "公众号先作为信源候选台账，不在第一阶段强行自动抓取",
    "保留原文链接、发布时间、来源机构和采集方式",
    "只生成摘要、标签、评分和咨询价值判断，避免复制完整版权内容"
  ],
  "source_types": [
    {
      "type": "government_policy",
      "label": "政府政策",
      "default_ingestion": "public_web_list_detail",
      "fields": ["title", "url", "published_at", "issuer", "policy_level", "region", "industry_tags", "summary", "consulting_value"]
    },
    {
      "type": "company_disclosure",
      "label": "公司公告",
      "default_ingestion": "public_disclosure_search_pdf",
      "fields": ["company", "ticker", "title", "url", "published_at", "announcement_type", "fiscal_period", "strategy_keywords", "summary"]
    },
    {
      "type": "consulting_insight",
      "label": "咨询洞察",
      "default_ingestion": "public_insight_page",
      "fields": ["firm", "title", "url", "published_at", "industry_tags", "framework_clues", "chart_clues", "summary", "ppt_use_case"]
    },
    {
      "type": "business_media",
      "label": "商业媒体",
      "default_ingestion": "public_web_monitor",
      "fields": ["source", "title", "url", "published_at", "company_entities", "sector", "event_type", "summary"]
    },
    {
      "type": "wechat_candidate",
      "label": "公众号候选",
      "default_ingestion": "manual_or_authorized",
      "fields": ["account_name", "topic_scope", "free_to_follow", "frequency", "compliance_status", "notes"]
    }
  ],
